<%# Connection slots fields partial %>
<% connection_slots = form.object.connection_slots || [] %>
<% if connection_slots.empty? %>
  <%# Render at least one empty slot field %>
  <% connection_slots = [{}] %>
<% end %>
<div class="form-control">
  <h3 class="text-lg font-semibold mb-2">Connection Slots</h3>
  <p class="text-sm opacity-70 mb-4">Define abstract connection slots with descriptive labels instead of selecting specific connections.</p>
  <% connection_slots.each_with_index do |slot, index| %>
    <div class="border border-base-300 rounded p-4 mb-4">
      <div class="grid grid-cols-2 gap-4">
        <div class="form-control">
          <%= form.label "connection_slots[#{index}][handle]", "Slot Handle", class: "label" %>
          <%= form.text_field "connection_slots[#{index}][handle]",
                value: slot['handle'],
                class: "input input-bordered w-full",
                placeholder: "slot-handle",
                required: true %>
          <label class="label">
            <span class="label-text-alt opacity-70">Lowercase letters, numbers, hyphens, underscores. Must be unique within workflow.</span>
          </label>
          <% if form.object.errors[:connection_slots].any? %>
            <div class="text-error text-sm mt-1">
              <% form.object.errors[:connection_slots].each do |error| %>
                <%= error %>
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="form-control">
          <%= form.label "connection_slots[#{index}][description]", "Description (optional)", class: "label" %>
          <%= form.text_field "connection_slots[#{index}][description]",
                value: slot['description'],
                class: "input input-bordered w-full",
                placeholder: "Slot description" %>
        </div>
      </div>
      <div class="form-control mt-4">
        <label class="label cursor-pointer justify-start gap-2">
          <%= form.check_box "connection_slots[#{index}][default]",
                checked: slot['default'] == true,
                class: "checkbox" %>
          <span class="label-text">Set as default connection slot</span>
        </label>
      </div>
    </div>
  <% end %>
</div>
