<div class="p-4 min-w-3/5 place-self-center">
  <h1 class="text-2xl font-bold mb-4">Workflow Execution <%= @workflow_execution.id %></h1>

  <%= turbo_frame_tag "row_executions",
        data: {
          "turbo-action": "replace",
          "controller": "reload-frame",
          "reload-frame-active-value": @row_executions.any? { |re| !re.complete? },
          "reload-frame-interval-value": 3000
        } do %>
    <div class="flex flex-wrap items-center gap-4 mb-2 text-sm text-neutral-content/70">
      <span>Workflow: <strong class="text-base-content"><%= @workflow_execution.workflow.name %></strong></span>
      <% if @workflow_execution.connection_mappings.present? %>
        <div class="flex items-center gap-2">
          <span class="opacity-70">Connections:</span>
          <% @workflow_execution.connection_mappings.each do |slot, metadata| %>
            <span class="badge badge-sm badge-outline" title="Slot: <%= slot %>">
              <%= metadata['connection_name'] %>
            </span>
          <% end %>
        </div>
      <% end %>
      <span>Rows: <%= @workflow_execution.row_executions.count %></span>
      <span>Processed: <%= @processed_count %></span>
      <span>Failed: <%= @failed_count %></span>
    </div>
    <div class="flex flex-wrap items-center gap-4 mb-6 text-sm text-neutral-content/70">
      <% if @workflow_execution.started_at.present? %>
        <span>Started: <%= @workflow_execution.started_at.strftime('%Y-%m-%d %H:%M:%S') %></span>
      <% end %>
      <% if @workflow_execution.completed_at.present? %>
        <span>Completed: <%= @workflow_execution.completed_at.strftime('%Y-%m-%d %H:%M:%S') %></span>
      <% end %>
    </div>

    <div class="rounded-box shadow-md bg-base-200 divide-y divide-base-300">
      <%= render partial: 'row_execution', collection: @row_executions %>
    </div>

    <div class="mt-4">
      <%= daisy_pagination(@pagy) %>
    </div>
  <% end %>
</div>
